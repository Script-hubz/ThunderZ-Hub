task.spawn(function()
    while mainFrame.Parent do
        TweenService:Create(uiStroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.6}):Play()
        task.wait(1.5)
        TweenService:Create(uiStroke, TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut), {Transparency = 0.2}):Play()
        task.wait(1.5)
    end
end)

task.delay(0.5, function()
    TweenService:Create(instructionsText, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(consoleLog, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(percentText, TweenInfo.new(0.3), {TextTransparency = 0}):Play()
    TweenService:Create(barBg, TweenInfo.new(0.3), {BackgroundTransparency = 0}):Play()
    TweenService:Create(joinBtn, TweenInfo.new(0.3), {BackgroundTransparency = 0, TextTransparency = 0}):Play()
    TweenService:Create(btnStroke, TweenInfo.new(0.3), {Transparency = 0.3}):Play()
    
    task.spawn(function()
        local nl = string.char(10)
        local fullText = "1. Click JOIN GROUP" .. nl .. "2. Link will be copied to your clipboard" .. nl .. "3. Paste link in Chrome" .. nl .. "4. Join group and enjoy your script"
        for i = 1, #fullText do
            instructionsText.Text = string.sub(fullText, 1, i)
            task.wait(0.015) 
        end
    end)

    task.spawn(function()
        local logs = {
            "[NET]: Establishing secure handshake...",
            "[NET]: Bypassing telemetry checks...",
            "[SYS]: Fetching latest offset keys...",
            "[MEM]: Injecting hooks into memory...",
            "[MEM]: Allocating dynamic buffers...",
            "[SYS]: Clearing crash logs...",
            "[NET]: Masking Hardware ID...",
            "[SYS]: Finalizing core modules..."
        }
        while percentText.Text ~= "100.0%" and percentText.Text ~= "SYSTEM BYPASSED" do
            consoleLog.Text = logs[math.random(1, #logs)]
            task.wait(math.random(15, 35) / 10) 
        end
        consoleLog.Text = "[SYS]: Injection Complete."
        consoleLog.TextColor3 = Color3.fromRGB(0, 255, 128) 
    end)

    TweenService:Create(fillBar, TweenInfo.new(45, Enum.EasingStyle.Linear), {Size = UDim2.new(0.9999, 0, 1, 0)}):Play()
    
    local startTick = tick()
    local duration = 45
    local connection
    connection = RunService.RenderStepped:Connect(function()
        local elapsed = tick() - startTick
        if elapsed >= duration then
            percentText.Text = "100.0%"
            connection:Disconnect()
            return
        end
        local percent = (elapsed / duration) * 100
        percentText.Text = string.format("%.1f%%", percent)
    end)
end)

task.delay(45.5, function()
    percentText.Text = "SYSTEM BYPASSED" 

    task.delay(5, function()
        TweenService:Create(bg, TweenInfo.new(0.5), {BackgroundTransparency = 1}):Play()
        local function fade(obj, time)
            if obj:IsA("GuiObject") then
                TweenService:Create(obj, TweenInfo.new(time), {BackgroundTransparency = 1, TextTransparency = 1}):Play()
            elseif obj:IsA("UIStroke") then
                TweenService:Create(obj, TweenInfo.new(time), {Transparency = 1}):Play()
            end
            for _, child in ipairs(obj:GetChildren()) do
                fade(child, time)
            end
        end
        fade(mainFrame, 0.5)

        task.wait(0.5)
        screenGui:Destroy()
    end)
end)
