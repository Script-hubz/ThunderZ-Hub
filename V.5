joinBtn.MouseButton1Click:Connect(function()
    pcall(function() if setclipboard then setclipboard(GroupLink) end end)
    local originalText = joinBtn.Text
    joinBtn.Text = "LINK COPIED!"
    TweenService:Create(joinBtn, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(0, 200, 100)}):Play()
    joinBtn.TextColor3 = Color3.fromRGB(0, 0, 0) 
    
    task.delay(2, function()
        joinBtn.Text = originalText
        TweenService:Create(joinBtn, TweenInfo.new(0.3), {BackgroundColor3 = Color3.fromRGB(60, 20, 100)}):Play()
        joinBtn.TextColor3 = Color3.fromRGB(0, 255, 128)
    end)
end)

